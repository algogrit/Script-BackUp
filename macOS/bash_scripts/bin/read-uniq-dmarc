#!/bin/bash

# Script to extract unique XML files from .xml.gz and .zip archives
# Usage: ./extract_xml_files.sh

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Create output directory
OUTPUT_DIR="extracted_xml_files"
mkdir -p "$OUTPUT_DIR"

echo -e "${BLUE}=== XML File Extraction Script ===${NC}"
echo -e "${BLUE}Output directory: $OUTPUT_DIR${NC}\n"

# Counter for statistics
count_gz=0
count_zip=0
count_xml=0
count_skipped=0

# Function to extract .xml.gz files
extract_gz_files() {
    echo -e "${GREEN}Extracting .xml.gz files...${NC}"

    # Find all unique .xml.gz files
    for file in *.xml.gz; do
        if [ -f "$file" ]; then
            # Extract the base filename without .gz extension
            output_file="${file%.gz}"
            output_path="$OUTPUT_DIR/$output_file"

            # Check if already extracted
            if [ -f "$output_path" ]; then
                echo -e "${YELLOW}Skipping (already exists): $file${NC}"
                ((count_skipped++))
            else
                echo "Extracting: $file -> $output_file"
                gunzip -c "$file" > "$output_path"
                ((count_gz++))
            fi
        fi
    done
}

# Function to extract XML files from .zip archives
extract_zip_files() {
    echo -e "\n${GREEN}Extracting .zip files...${NC}"

    for zipfile in *.zip; do
        if [ -f "$zipfile" ]; then
            echo "Processing: $zipfile"

            # List contents of zip file
            xml_files=$(unzip -l "$zipfile" | grep -i '\.xml$' | awk '{print $NF}')

            if [ -n "$xml_files" ]; then
                # Extract only XML files from the zip
                while IFS= read -r xml_file; do
                    # Check if file already exists in output directory
                    if [ -f "$OUTPUT_DIR/$xml_file" ]; then
                        echo -e "${YELLOW}  Skipping (already exists): $xml_file${NC}"
                        ((count_skipped++))
                    else
                        echo "  Extracting: $xml_file"
                        unzip -q -j "$zipfile" "$xml_file" -d "$OUTPUT_DIR"
                        ((count_zip++))
                    fi
                done <<< "$xml_files"
            else
                echo -e "${YELLOW}  No XML files found in $zipfile${NC}"
            fi
        fi
    done
}

# Function to copy standalone .xml files
copy_xml_files() {
    echo -e "\n${GREEN}Copying standalone .xml files...${NC}"

    for file in *.xml; do
        if [ -f "$file" ]; then
            output_path="$OUTPUT_DIR/$file"

            if [ -f "$output_path" ]; then
                echo -e "${YELLOW}Skipping (already exists): $file${NC}"
                ((count_skipped++))
            else
                echo "Copying: $file"
                cp "$file" "$OUTPUT_DIR/"
                ((count_xml++))
            fi
        fi
    done
}

# Main execution
extract_gz_files
extract_zip_files
copy_xml_files

# Summary
echo -e "\n${BLUE}=== Extraction Complete ===${NC}"
echo -e "Files extracted from .xml.gz: ${GREEN}$count_gz${NC}"
echo -e "Files extracted from .zip:    ${GREEN}$count_zip${NC}"
echo -e "Standalone .xml files copied: ${GREEN}$count_xml${NC}"
echo -e "Files skipped (duplicates):   ${YELLOW}$count_skipped${NC}"
echo -e "\nTotal XML files in output:    ${GREEN}$(ls -1 "$OUTPUT_DIR"/*.xml 2>/dev/null | wc -l)${NC}"
echo -e "\nAll files saved to: ${BLUE}$OUTPUT_DIR/${NC}"

cat $OUTPUT_DIR/*.xml | pbcopy
echo -e "\nCopied to clipboard."
