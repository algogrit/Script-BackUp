if bash_startup_debug_enabled; then
  echo -e "\033[1;34m~/bash_scripts/.bash_paths Loaded\033[0m"
fi

## macOS cleanups
clean_cryptex() {
  local cleaned=""
  local IFS=':'
  for p in $PATH; do
    if [[ "$p" != /var/run/com.apple.security.cryptexd/* ]]; then
      cleaned="${cleaned:+$cleaned:}$p"
    fi
  done
  export PATH="$cleaned"
}
clean_cryptex

# Added by LM Studio CLI (lms)
export PATH="$PATH:/Users/gaurav/.lmstudio/bin"
# End of LM Studio CLI section

# Added by Antigravity
export PATH="/Users/gaurav/.antigravity/antigravity/bin:$PATH"

### Languages

# Elm
export ELM_HOME=~/.elm

# Language Version Managers
## rbenv
export RBENV_ROOT=/usr/local/var/rbenv # Create rubies in Brew
if bash_startup_optional_enabled && command -v rbenv >/dev/null 2>&1; then
  eval "$(rbenv init -)"
fi

## fnm over nodenv
if bash_startup_optional_enabled && command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd --shell bash)"
fi

## pyenv
if bash_startup_optional_enabled && command -v pyenv >/dev/null 2>&1; then
  #eval "$(pyenv init -)"
  #eval "$(pyenv virtualenv-init -)"
  export PYENV_ROOT="$HOME/.pyenv"
  if [ -d "$PYENV_ROOT/bin" ]; then
    export PATH="$PYENV_ROOT/bin:$PATH"
  fi
  eval "$(pyenv init --path)"
fi

## goenv
export GOENV_ROOT="$HOME/.goenv"
export GOPATH=$GOENV_ROOT
export PATH="$GOPATH/bin:$PATH"
export GOENV_DISABLE_GOROOT=1
export GOENV_DISABLE_GOPATH=1
if bash_startup_optional_enabled && command -v goenv >/dev/null 2>&1; then
  eval "$(goenv init -)"
fi

## rustup-init
export CARGO_HOME="$HOME/.cargo"
export PATH="$CARGO_HOME/bin:$PATH"
if [ -f "$HOME/.cargo/env" ]; then
  # shellcheck source=/dev/null
  . "$HOME/.cargo/env"
fi

## jenv
export PATH="$HOME/.jenv/bin:$PATH"
if bash_startup_optional_enabled && command -v jenv >/dev/null 2>&1; then
  eval "$(jenv init -)"
fi

## vcpkg
export VCPKG_ROOT="$HOME/vcpkg"
export CPLUS_INCLUDE_PATH="$HOME/vcpkg/installed/arm64-osx/include:$CPLUS_INCLUDE_PATH"
if [ -d $HOME/vcpkg/installed ]; then
  for d in $HOME/vcpkg/installed/arm64-osx/tools/*; do PATH="$d:$PATH"; done
fi

