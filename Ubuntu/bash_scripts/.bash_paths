if bash_startup_debug_enabled; then
  echo -e "\033[1;36m~/bash_scripts/.bash_paths Loaded\033[0m"
fi

### Tools
# Setting pkg config path
export PKG_CONFIG_PATH=/usr/lib/x86_64-linux-gnu/pkgconfig:/usr/share/pkgconfig:/usr/lib/pkgconfig

# Z
export _Z_DATA=~/.z

### Languages

# Elm
export ELM_HOME=~/.elm

# Language Version Managers
## rbenv
if bash_startup_optional_enabled && [ -x ~/.rbenv/bin/rbenv ]; then
  eval "$(~/.rbenv/bin/rbenv init - --no-rehash bash)"
fi
export PATH="$HOME/.rbenv/plugins/ruby-build/bin:$PATH"

## nodenv
# export PATH="$HOME/.nodenv/bin:$PATH"
# if which nodenv > /dev/null; then eval "$(nodenv init -)"; fi

## pyenv
if bash_startup_optional_enabled && command -v pyenv >/dev/null 2>&1; then
  #eval "$(pyenv init -)"
  #eval "$(pyenv virtualenv-init -)"
  export PYENV_ROOT="$HOME/.pyenv"
  export PATH="$PYENV_ROOT/bin:$PATH"
  eval "$(pyenv init --path)"
fi

# Added by `nodenv init` on Sun Mar  1 04:58:07 PM IST 2026
if bash_startup_optional_enabled && command -v nodenv >/dev/null 2>&1; then
  eval "$(nodenv init - --no-rehash bash)"
fi

## goenv
# export GOENV_ROOT="$HOME/.goenv"
# export GOPATH=$GOENV_ROOT
# export PATH="$GOPATH/bin:$PATH"
# export GOENV_DISABLE_GOROOT=1
# export GOENV_DISABLE_GOPATH=1
# eval "$(goenv init -)"

## rustup-init
# export CARGO_HOME="$HOME/.cargo"
# export PATH="$CARGO_HOME/bin:$PATH"
# . $HOME/.cargo/env

## jenv
# export PATH="$HOME/.jenv/bin:$PATH"
# eval "$(jenv init -)"

# ## vcpkg
# export VCPKG_ROOT="$HOME/vcpkg"
# export CPLUS_INCLUDE_PATH="$HOME/vcpkg/installed/arm64-osx/include:$CPLUS_INCLUDE_PATH"
# for d in $HOME/vcpkg/installed/arm64-osx/tools/*; do PATH="$d:$PATH"; done

#### CUSTOM

# Load custom git commands
if bash_startup_debug_enabled; then
  echo -e "\033[1;36m~/Custom-Git-Commands Loaded\033[0m"
fi
export PATH="$HOME/Custom-Git-Commands:$PATH"

# Adding ~/bin to the PATH
export PATH="$HOME/bin:$PATH"

# Adding ~/.local/bin to the PATH
export PATH="~/.local/bin:$PATH"

# ADDING snippet_programs to the PATH
export PATH="$HOME/bash_scripts/bin:$PATH"
