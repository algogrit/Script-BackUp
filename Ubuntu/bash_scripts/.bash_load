[ -f ~/bash_scripts/.bash_startup_helpers ] && . ~/bash_scripts/.bash_startup_helpers
if bash_startup_debug_enabled; then
  echo -e "\033[1;36m~/bash_scripts/.bash_load Loaded\033[0m"
fi

if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Sourcing Bash Paths and language env for all shells
bash_startup_source ~/bash_scripts/.bash_paths
bash_startup_source ~/bash_scripts/.bash_languages

if bash_startup_optional_enabled; then
  bash_startup_source ~/bash_scripts/.bash_completion
  bash_startup_source ~/bash_scripts/.bash_customizations
  bash_startup_source ~/bash_scripts/.bash_custom_functions
  bash_startup_source ~/bash_scripts/.aliases

  if [ -f ~/bash_scripts/third_party/z.sh ]; then
    # shellcheck source=/dev/null
    . ~/bash_scripts/third_party/z.sh
  fi

  if [ -f /home/linuxbrew/.linuxbrew/opt/autoenv/activate.sh ]; then
    # shellcheck source=/dev/null
    . /home/linuxbrew/.linuxbrew/opt/autoenv/activate.sh
  fi

  # # Source Docker Init script
  # source /Users/gaurav/.docker/init-bash.sh || true

  # # Sourcing Direnv
  # eval "$(direnv hook bash)"
fi

# Source cargo env - Rustup
# . "$HOME/.cargo/env"

if [ "${BASH_STARTUP_CLEAR_HISTORY:-0}" = "1" ]; then
  > ~/.bash_history && history -c
fi
